{
  "name": "@gogaadi/source",
  "version": "1.0.0",
  "license": "MIT",
  "keywords": [
    "express",
    "nodejs",
    "monorepo",
    "api",
    "backend",
    "frontend",
    "react",
    "typescript"
  ],
  "scripts": {
    "build": "vite build --config web/vite.config.mts",
    "build:administration": "vite build --config web/vite.config.mts",
    "build:backend": "tsc --project tsconfig.backend.json",
    "build:backend:clean": "rimraf dist && npm run build:backend",
    "serve:administration": "vite preview --config web/vite.config.mts",
    "start:backend": "ts-node -r tsconfig-paths/register --project=tsconfig.app.json gateways/src/index.ts",
    "dev:backend": "nodemon --config nodemon.json",
    "dev:admin-web": "vite --config web/vite.config.mts",
    "dev:mobile": "cd mobile && npm run start",
    "dev:mobile:android": "cd mobile && npm run android",
    "dev:mobile:ios": "cd mobile && npm run ios",
    "install:mobile": "cd mobile && npm install",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "fix:all": "npm run lint:fix && npm run format",
    "storybook": "cross-env NODE_OPTIONS=--no-warnings storybook dev -p 6006",
    "build-storybook": "cross-env NODE_OPTIONS=--no-warnings storybook build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "validate": "npm run format:check && npm run lint && npm run type-check",
    "prisma:generate": "prisma generate ",
    "prisma:migrate": "prisma db push ",
    "prisma:sync": "ts-node gateways/prisma/scripts/sync-schema.ts",
    "prisma:regenerate": "ts-node gateways/prisma/scripts/regenerate-migration.ts",
    "prisma:deploy": "prisma migrate deploy ",
    "prisma:seed": "ts-node --project tsconfig.app.json gateways/prisma/seed.ts",
    "seed:admin": "ts-node --project tsconfig.app.json gateways/prisma/seed-admin.ts",
    "db:migrate": "ts-node --project tsconfig.app.json gateways/prisma/migrate-schema.ts",
    "prisma:studio": "prisma studio ",
    "prisma:reset": "prisma migrate reset --force ",
    "prepare": "husky install || true"
  },
  "private": true,
  "prisma": {
    "schema": "gateways/prisma/schema.prisma",
    "seed": "ts-node gateways/prisma/seed.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.5",
    "@mui/x-date-pickers": "^8.27.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.4.2",
    "@reduxjs/toolkit": "^2.10.1",
    "@types/multer": "^2.1.0",
    "apexcharts": "^5.3.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "formik": "^2.4.9",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.13",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-apexcharts": "^1.8.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "6.29.0",
    "tesseract.js": "^7.0.0",
    "tss-react": "^4.9.19",
    "winston": "^3.19.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@storybook/react": "^10.1.9",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.25",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.0.11",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "nodemon": "^3.0.2",
    "prettier": "^3.7.4",
    "prisma": "^7.5.0",
    "rimraf": "^5.0.5",
    "storybook": "^10.1.9",
    "ts-jest": "^29.4.6",
    "ts-node": "10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^5.4.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ]
}
