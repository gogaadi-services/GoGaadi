  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"],
    "sourceMap": false
  },
  "include": ["gateways/**/*", "libs/core/**/*", "libs/shared/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"]
}
