{
  "compileOnSave": false,
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "rootDir": ".",
    "sourceMap": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["es2020", "esnext", "dom", "dom.iterable"],
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "module": "esnext",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types", "./typings"],
    "paths": {
      "@gogaadi/component": ["libs/ui/components/index.ts"],
      "@gogaadi/component/*": ["libs/ui/components/*"],
      "@gogaadi/theme": ["libs/theme/index.ts"],
      "@gogaadi/interfaces": ["libs/entities/index.ts"],
      "@gogaadi/hooks": ["libs/ui/hooks/index.ts"],
      "@gogaadi/utils": ["libs/utils/index.ts"],
      "@gogaadi/pages/*": ["libs/ui/pages/*"],
      "@gogaadi/constants": ["libs/shared/constants/index.ts"],
      "@gogaadi/middleware": ["libs/core/middleware/index.ts"],
      "@gogaadi/config": ["libs/core/config/index.ts"],
      "@gogaadi/database": ["libs/core/database/index.ts"],
      "@gogaadi/core": ["libs/core/index.ts"],
      "@gogaadi/services": ["libs/services/index.ts"],
      "@gogaadi/store": ["libs/ui/store/index.ts"],
      "@gogaadi/slices": ["libs/ui/slices/index.ts"],
      "@gogaadi/state": ["libs/ui/state/index.ts"]
    }
  },
  "exclude": ["dist", "node_modules", "temp"]
}
